# Copy this file to .env and fill in your own values.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ACCESS_TOKEN=change_me_to_a_long_random_token

# OpenRouter / OpenAI-compatible provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace_with_your_new_key
LLM_PRIMARY_MODEL=openai/gpt-4o
LLM_SUMMARY_MODEL=openai/gpt-4o-mini

# Optional request metadata for OpenRouter
OR_SITE_URL=http://localhost:8000
OR_APP_NAME=Lin System

# Optional reverse proxy
PUBLIC_BASE_URL=http://localhost:8000
