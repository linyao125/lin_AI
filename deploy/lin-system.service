[Unit]
Description=Lin Companion System
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/lin_system
EnvironmentFile=/opt/lin_system/.env
ExecStart=/opt/lin_system/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
