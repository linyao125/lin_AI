# =========================
# LIN_AI 配置文件
# =========================
# 👉 只需要修改：LLM_API_KEY


# 基础配置（不要改）
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000

# 访问令牌（可随便填一串）
ACCESS_TOKEN=your_token_here


# LLM 配置（必须）
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key
LLM_PRIMARY_MODEL=openai/gpt-4o-mini
LLM_SUMMARY_MODEL=openai/gpt-4o-mini


# OpenRouter 标识（可不改）
OR_SITE_URL=http://localhost:8000
OR_APP_NAME=LIN_AI


# 部署后建议修改为公网地址
PUBLIC_BASE_URL=http://localhost:8000
